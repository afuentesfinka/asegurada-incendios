generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  propietario
  presidente
  administrador
  operador_interno
}

enum CompaniaEstado {
  visible
  oculta
  destacada
}

model Usuario {
  id             String      @id @default(cuid())
  nombre         String
  email          String      @unique
  telefono       String?
  rol            Role
  consentimientos Json?
  comunidades    Comunidad[] @relation("AdministradorComunidades")
  leads          Lead[]
  createdAt      DateTime    @default(now())
}

model Comunidad {
  id              String        @id @default(cuid())
  direccion       String
  catastro        String?
  codigoPostal    String?
  anio            Int?
  numeroViviendas Int?
  metrosCuadrados Float?
  caracteristicas Json?
  administradorId String?
  administrador   Usuario?      @relation("AdministradorComunidades", fields: [administradorId], references: [id])
  polizas         Poliza[]
  diagnosticos    Diagnostico[]
}

model Poliza {
  id                 String    @id @default(cuid())
  compania           String
  capitales          Json?
  coberturas         Json?
  vencimiento        DateTime?
  pdfUrl             String?
  comunidadId        String
  comunidad          Comunidad @relation(fields: [comunidadId], references: [id])
  companiaRelacionId String?
  companiaRelacion   Compania? @relation(fields: [companiaRelacionId], references: [id])
}

model Diagnostico {
  id          String    @id @default(cuid())
  fecha       DateTime  @default(now())
  score       Int
  alertas     Json?
  informe     Json?
  comunidadId String
  comunidad   Comunidad @relation(fields: [comunidadId], references: [id])
  lead        Lead?
}

model Compania {
  id          String          @id @default(cuid())
  nombre      String
  logo        String?
  estado      CompaniaEstado  @default(visible)
  acuerdo     String?
  descripcion String?
  contacto    String?
  productos   Json?
  polizas     Poliza[]
  condiciones Condiciones[]
}

model Condiciones {
  id                     String   @id @default(cuid())
  producto               String
  coberturasNormalizadas Json
  pdfUrl                 String?
  vectorRef              String?
  companiaId             String
  compania               Compania @relation(fields: [companiaId], references: [id])
}

model Lead {
  id              String      @id @default(cuid())
  estado          String
  asesorAsignado  String?
  seguimiento     Json?
  diagnosticoId   String      @unique
  diagnostico     Diagnostico @relation(fields: [diagnosticoId], references: [id])
  usuarioId       String
  usuario         Usuario     @relation(fields: [usuarioId], references: [id])
}
