generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  propietario
  presidente
  administrador
  operador_interno
}

enum CompaniaEstado {
  visible
  oculta
  destacada
}

enum TipoSiniestro {
  agua
  incendio
  RC
  cristales
  otros
}

enum OrigenLead {
  web
  finka
}

model Usuario {
  id              String      @id @default(cuid())
  nombre          String
  email           String      @unique
  telefono        String?
  rol             Role
  consentimientos Json?
  origenFinka     Boolean     @default(false)
  comunidades     Comunidad[] @relation("AdministradorComunidades")
  leads           Lead[]
  createdAt       DateTime    @default(now())
}

model Comunidad {
  id                String            @id @default(cuid())
  direccion         String
  catastro          String?
  codigoPostal      String?
  poblacion         String?
  anio              Int?
  numeroViviendas   Int?
  numeroPlantas     Int?
  metrosCuadrados   Float?
  caracteristicas   Json?
  administradorId   String?
  administrador     Usuario?          @relation("AdministradorComunidades", fields: [administradorId], references: [id])
  polizas           Poliza[]
  diagnosticos      Diagnostico[]
  siniestros        Siniestro[]
  portalPresidente  PortalPresidente?
}

model Poliza {
  id                 String      @id @default(cuid())
  compania           String
  capitales          Json?
  coberturas         Json?
  vencimiento        DateTime?
  pdfUrl             String?
  comunidadId        String
  comunidad          Comunidad   @relation(fields: [comunidadId], references: [id])
  companiaRelacionId String?
  companiaRelacion   Compania?   @relation(fields: [companiaRelacionId], references: [id])
  siniestros         Siniestro[]
}

model Diagnostico {
  id                String    @id @default(cuid())
  fecha             DateTime  @default(now())
  score             Int
  alertas           Json?
  informe           Json?
  consentimientoRgpd Boolean
  comunidadId       String
  comunidad         Comunidad @relation(fields: [comunidadId], references: [id])
  lead              Lead?
}

model Siniestro {
  id            String        @id @default(cuid())
  tipo          TipoSiniestro
  estado        String
  fechaApertura DateTime      @default(now())
  descripcion   String
  documentos    Json?
  urgencia      String
  ruta          String
  comunidadId   String
  polizaId      String
  comunidad     Comunidad     @relation(fields: [comunidadId], references: [id])
  poliza        Poliza        @relation(fields: [polizaId], references: [id])
}

model PortalPresidente {
  id                        String    @id @default(cuid())
  enlaceSeguro              String
  coberturasLenguajeClaro   Json
  contactosUrgencia         Json
  comunidadId               String    @unique
  comunidad                 Comunidad @relation(fields: [comunidadId], references: [id])
}

model Compania {
  id          String          @id @default(cuid())
  nombre      String
  logo        String?
  estado      CompaniaEstado  @default(visible)
  acuerdo     String?
  descripcion String?
  contacto    String?
  productos   Json?
  polizas     Poliza[]
  condiciones Condiciones[]
}

model Condiciones {
  id                     String   @id @default(cuid())
  producto               String
  coberturasNormalizadas Json
  pdfUrl                 String?
  vectorRef              String?
  companiaId             String
  compania               Compania @relation(fields: [companiaId], references: [id])
}

model Lead {
  id              String      @id @default(cuid())
  estado          String
  asesorAsignado  String?
  seguimiento     Json?
  origen          OrigenLead  @default(web)
  diagnosticoId   String      @unique
  diagnostico     Diagnostico @relation(fields: [diagnosticoId], references: [id])
  usuarioId       String
  usuario         Usuario     @relation(fields: [usuarioId], references: [id])
}
